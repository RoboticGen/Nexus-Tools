# Environment Variables
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_NAME=obo-code
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Nexus Tools API (file saving backend)
# Dev: http://localhost:3004/api/v1  |  Prod: <add production URL>
NEXT_PUBLIC_NEXUS_TOOLS_API_URL=http://localhost:3004/api/v1
